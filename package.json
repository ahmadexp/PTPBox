{
  "name": "ptpbox-console",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "build:standalone": "vite build --config vite.standalone.config.ts",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "test": "npm run build && node --test tests/rendered-html.test.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern dist-standalone --ignore-pattern .next --ignore-pattern .vinext",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "drizzle-orm": "0.45.2",
    "lucide-react": "^0.468.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.2.1",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module",
  "description": "Precision Time Protocol cascade observability and control room",
  "author": "Ahmad Byagowi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ahmadexp/PTPBox.git"
  },
  "homepage": "https://github.com/ahmadexp/PTPBox#readme",
  "bugs": {
    "url": "https://github.com/ahmadexp/PTPBox/issues"
  },
  "keywords": [
    "ptp",
    "ieee-1588",
    "linuxptp",
    "precision-time",
    "hardware-timestamping",
    "network-namespaces"
  ]
}
